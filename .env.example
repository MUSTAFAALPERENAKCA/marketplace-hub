# Veritabanı (yerel Docker postgres, docker-compose.yml ile uyumlu)
DATABASE_URL=postgresql://marketplace_hub:marketplace_hub@localhost:5433/marketplace_hub

# Pazaryeri modu: "mock" (gerçek API anahtarı gerektirmez) | "live"
MARKETPLACE_MODE=mock

# Clerk (auth + organizations)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# AI
ANTHROPIC_API_KEY=

# WhatsApp / Instagram (Meta) — bot kanalları için, sonraki fazda kullanılacak
WHATSAPP_META_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
INSTAGRAM_PAGE_ID=
INSTAGRAM_PAGE_ACCESS_TOKEN=
